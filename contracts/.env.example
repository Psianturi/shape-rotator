# Sepolia RPC (Infura, Alchemy, or public)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<YOUR_INFURA_KEY>

# Deployer wallet (funded with Sepolia ETH)
DEPLOYER_PRIVATE_KEY=0x<deployer_private_key>

# User signer address (wallet that signs transfers)
USER_SIGNER_ADDRESS=0x<user_signer_address>

# Guardian signer address (must match guardian_account in backend)
# Get this from GET /health -> guardian_signer_address
GUARDIAN_SIGNER_ADDRESS=0x<guardian_signer_address>

# Backend URL
BACKEND_URL=http://127.0.0.1:8000

# User ID from /register response
USER_ID=user_xxxxxxxxxx
